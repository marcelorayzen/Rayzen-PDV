{
  "name": "rayzen-pdv-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "electron"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "dev": "tsc -b tsconfig.json --watch --preserveWatchOutput",
    "test": "node ./scripts/run-workspace-tests.mjs",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --selectProjects unit --runInBand",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --selectProjects integration --runInBand",
    "test:smoke:offline": "node ./scripts/run-smoke-offline.mjs",
    "test:smoke:install": "node ./scripts/run-install-smoke.mjs",
    "test:validate:printing": "node ./scripts/run-print-validation.mjs",
    "test:validate:cash": "node ./scripts/run-cash-validation.mjs",
    "qa:homolog": "node ./scripts/run-qa-release-profile.mjs homolog",
    "qa:pilot": "node ./scripts/run-qa-release-profile.mjs pilot",
    "lint": "eslint \"apps/pdv/src/**/*.ts\" \"electron/src/**/*.ts\" \"packages/*/src/**/*.ts\" --max-warnings 0",
    "clean": "tsc -b tsconfig.json --clean",
    "package:win": "pnpm build && pnpm --filter @rayzen/electron package:win",
    "make:win": "pnpm build && pnpm --filter @rayzen/electron make:win",
    "make:installer:win": "pnpm build && pnpm --filter @rayzen/electron make:installer:win",
    "release:manual": "node ./scripts/run-windows-distribution.mjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/node": "22.15.29",
    "electron": "^41.0.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.57.2"
  }
}
