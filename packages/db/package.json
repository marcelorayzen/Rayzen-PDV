{
  "name": "@rayzen/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "test": "tsc -p tsconfig.json && node test/run-db-foundation-tests.mjs",
    "migrate:check": "node ../../scripts/check-db-migrations.mjs"
  }
}
